#!/usr/bin/env bash
# SessionStart hook for powershell-safety
# Reads session-start-content.md, wraps in JSON, outputs on stdout.
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONTENT_FILE="$SCRIPT_DIR/session-start-content.md"

if [ ! -f "$CONTENT_FILE" ]; then
    echo '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"powershell-safety active (content file missing)"}}'
    exit 0
fi

# JSON-escape and wrap: escape backslash, quote, then newlines become \n
CONTENT=$(cat "$CONTENT_FILE")
ESCAPED=$(printf '%s' "$CONTENT" | sed 's/\\/\\\\/g; s/"/\\"/g' | awk '{printf "%s\\n", $0}')

printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$ESCAPED"
